  client/.env.*
  server/.env
  server/.env.*

  # logs
  *.log
  npm-debug.log*
  yarn-debug.log*
  yarn-error.log*

  # OS / editor
  .DS_Store
  Thumbs.db
  .vscode/
  .idea/